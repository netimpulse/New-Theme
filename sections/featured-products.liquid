{%- liquid
  assign coll = section.settings.collection
  assign limit = section.settings.limit
-%}
<section class="fp" data-section-id="{{ section.id }}">
  <div class="fp__head">
    {%- if section.settings.heading != blank -%}<h2 class="fp__title">{{ section.settings.heading | escape }}</h2>{%- endif -%}
    {%- if coll != blank -%}<a class="fp__view-all" href="{{ coll.url }}">Alle anzeigen →</a>{%- endif -%}
  </div>
  <div class="fp__grid" style="--cols: {{ section.settings.columns }};">
    {%- if coll != blank -%}
      {%- for product in coll.products limit: limit -%}
        {%- render 'product-card', product: product, show_vendor: section.settings.show_vendor -%}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        {%- render 'product-card' -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>
{% style %}
  #shopify-section-{{ section.id }} {
    --fp-bg: {{ section.settings.bg_color }};
    --fp-fg: {{ section.settings.text_color }};
    --fp-padding-top: {{ section.settings.padding_top }}px;
    --fp-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}
{{ 'section-featured-products.css' | asset_url | stylesheet_tag }}
{% schema %}
{
  "name": "Produkt-Grid",
  "tag": "section",
  "class": "section-featured-products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Bestseller" },
    { "type": "collection", "id": "collection", "label": "Kollektion" },
    { "type": "range", "id": "limit", "min": 2, "max": 24, "step": 1, "label": "Max. Produkte", "default": 8 },
    { "type": "range", "id": "columns", "min": 2, "max": 6, "step": 1, "label": "Spalten (Desktop)", "default": 4 },
    { "type": "checkbox", "id": "show_vendor", "label": "Marke anzeigen", "default": false },
    { "type": "color", "id": "bg_color", "label": "Hintergrund", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#111111" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Abstand oben", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Abstand unten", "default": 56 }
  ],
  "presets": [ { "name": "Produkt-Grid" } ],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
