<section class="iwt iwt--img-{{ section.settings.image_side }}" data-section-id="{{ section.id }}">
  <div class="iwt__grid">
    <div class="iwt__media">
      {%- if section.settings.image \!= blank -%}
        {{ section.settings.image | image_url: width: 1400 | image_tag:
           loading: 'lazy',
           sizes: '(min-width: 990px) 50vw, 100vw',
           widths: '450,600,900,1200,1400',
           alt: section.settings.heading | default: '' | escape,
           class: 'iwt__image' }}
      {%- else -%}
        <div class="iwt__placeholder">{{ 'lifestyle-2' | placeholder_svg_tag }}</div>
      {%- endif -%}
    </div>
    <div class="iwt__content">
      {%- if section.settings.eyebrow \!= blank -%}<p class="iwt__eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading \!= blank -%}<h2 class="iwt__heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.text \!= blank -%}<div class="iwt__text">{{ section.settings.text }}</div>{%- endif -%}
      {%- if section.settings.button_label \!= blank and section.settings.button_link \!= blank -%}
        <a class="iwt__btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label | escape }}</a>
      {%- endif -%}
    </div>
  </div>
</section>
{% style %}
  #shopify-section-{{ section.id }} {
    --iwt-bg: {{ section.settings.bg_color }};
    --iwt-fg: {{ section.settings.text_color }};
    --iwt-padding-top: {{ section.settings.padding_top }}px;
    --iwt-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}
{{ 'section-image-with-text.css' | asset_url | stylesheet_tag }}
{% schema %}
{
  "name": "Bild mit Text",
  "tag": "section",
  "class": "section-image-with-text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Bild" },
    {
      "type": "select", "id": "image_side", "label": "Bild-Seite", "default": "left",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ]
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Unsere Geschichte" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Zeitlose Mode, sorgfältig gemacht" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Wir designen in Berlin und produzieren in Portugal – mit zertifizierten Materialien und kurzen Lieferketten.</p>" },
    { "type": "text", "id": "button_label", "label": "Button-Text", "default": "Mehr erfahren" },
    { "type": "url", "id": "button_link", "label": "Button-Link" },
    { "type": "color", "id": "bg_color", "label": "Hintergrund", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#111111" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Abstand oben", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Abstand unten", "default": 48 }
  ],
  "presets": [ { "name": "Bild mit Text" } ],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
