<section class="tm color-scheme color-{{ section.settings.color_scheme.id }}" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}<h2 class="tm__heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
  <div class="tm__grid" style="--cols: {{ section.settings.columns }};">
    {%- for block in section.blocks -%}
      <figure class="tm__card" {{ block.shopify_attributes }}>
        {%- if block.settings.rating > 0 -%}
          <div class="tm__stars" aria-label="{{ block.settings.rating }} von 5 Sternen">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}★{%- else -%}☆{%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
        <blockquote class="tm__quote">{{ block.settings.quote }}</blockquote>
        <figcaption class="tm__author">
          <strong>{{ block.settings.author | escape }}</strong>
          {%- if block.settings.meta != blank -%}<span>{{ block.settings.meta | escape }}</span>{%- endif -%}
        </figcaption>
      </figure>
    {%- endfor -%}
  </div>
</section>
{% style %}
  {%- assign scheme = section.settings.color_scheme -%}
  {%- if scheme -%}
  .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
    --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
    --color-button: {{ scheme.settings.button_background.red }}, {{ scheme.settings.button_background.green }}, {{ scheme.settings.button_background.blue }};
    --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
    --color-secondary-button-label: {{ scheme.settings.secondary_button_label.red }}, {{ scheme.settings.secondary_button_label.green }}, {{ scheme.settings.secondary_button_label.blue }};
    --color-border: {{ scheme.settings.border.red }}, {{ scheme.settings.border.green }}, {{ scheme.settings.border.blue }};
    color: rgb(var(--color-text));
    background-color: rgb(var(--color-background));
    {%- if scheme.settings.background_gradient != blank -%}
    background-image: {{ scheme.settings.background_gradient }};
    {%- endif -%}
  }
  {%- endif -%}

  #shopify-section-{{ section.id }} {
    --tm-bg: {{ section.settings.bg_color }};
    --tm-fg: {{ section.settings.text_color }};
    --tm-padding-top: {{ section.settings.padding_top }}px;
    --tm-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}
{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}
{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Farbschema",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Was unsere Kund:innen sagen"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Spalten (Desktop)",
      "default": 3
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrund",
      "default": "#f6f5f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "limit": 9,
      "settings": [
        {
          "type": "richtext",
          "id": "quote",
          "label": "Zitat",
          "default": "<p>Fantastische Qualität, sitzt perfekt und ein schneller Versand. 5 von 5 Sternen.</p>"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Autor:in",
          "default": "Lena K."
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta (z.B. Produkt)",
          "default": "Verifizierte Käuferin"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "label": "Sterne",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ],
      "settings": {
        "color_scheme": "scheme-1"
      }
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  }
}
{% endschema %}
