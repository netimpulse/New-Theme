<footer class="site-footer" role="contentinfo" data-section-id="{{ section.id }}">
  <div class="site-footer__inner">
    {%- comment -%} Brand / about column {%- endcomment -%}
    <div class="site-footer__col site-footer__col--brand">
      {%- if section.settings.logo \!= blank -%}
        {{
          section.settings.logo
          | image_url: width: 300
          | image_tag:
            loading: 'lazy',
            sizes: '160px',
            widths: '160,240,320',
            alt: shop.name | escape,
            class: 'site-footer__logo'
        }}
      {%- else -%}
        <p class="site-footer__brand">{{ shop.name | escape }}</p>
      {%- endif -%}

      {%- if section.settings.about \!= blank -%}
        <div class="site-footer__about">{{ section.settings.about }}</div>
      {%- endif -%}

      {%- if section.settings.show_socials -%}
        <ul class="site-footer__socials" role="list">
          {%- if section.settings.social_instagram \!= blank -%}
            <li><a href="{{ section.settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">{{ 'icon-instagram.svg' | inline_asset_content }}</a></li>
          {%- endif -%}
          {%- if section.settings.social_tiktok \!= blank -%}
            <li><a href="{{ section.settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">{{ 'icon-tiktok.svg' | inline_asset_content }}</a></li>
          {%- endif -%}
          {%- if section.settings.social_facebook \!= blank -%}
            <li><a href="{{ section.settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">{{ 'icon-facebook.svg' | inline_asset_content }}</a></li>
          {%- endif -%}
          {%- if section.settings.social_youtube \!= blank -%}
            <li><a href="{{ section.settings.social_youtube }}" aria-label="YouTube" target="_blank" rel="noopener">{{ 'icon-youtube.svg' | inline_asset_content }}</a></li>
          {%- endif -%}
          {%- if section.settings.social_pinterest \!= blank -%}
            <li><a href="{{ section.settings.social_pinterest }}" aria-label="Pinterest" target="_blank" rel="noopener">{{ 'icon-pinterest.svg' | inline_asset_content }}</a></li>
          {%- endif -%}
        </ul>
      {%- endif -%}
    </div>

    {%- comment -%} Menu columns via blocks {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'menu' -%}
          <div class="site-footer__col site-footer__col--menu" {{ block.shopify_attributes }}>
            <h4 class="site-footer__heading">{{ block.settings.heading | escape }}</h4>
            {%- if block.settings.menu \!= blank -%}
              <ul class="site-footer__list" role="list">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- when 'text' -%}
          <div class="site-footer__col site-footer__col--text" {{ block.shopify_attributes }}>
            <h4 class="site-footer__heading">{{ block.settings.heading | escape }}</h4>
            {%- if block.settings.text \!= blank -%}
              <div class="site-footer__text">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        {%- when 'newsletter' -%}
          <div class="site-footer__col site-footer__col--newsletter" {{ block.shopify_attributes }}>
            <h4 class="site-footer__heading">{{ block.settings.heading | escape }}</h4>
            {%- if block.settings.text \!= blank -%}
              <p class="site-footer__newsletter-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
            {%- form 'customer', class: 'site-footer__newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <label for="FooterNewsletter-{{ section.id }}" class="visually-hidden">E-Mail-Adresse</label>
              <div class="site-footer__newsletter-inputs">
                <input
                  id="FooterNewsletter-{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  placeholder="{{ block.settings.placeholder | default: 'E-Mail-Adresse' | escape }}"
                  autocomplete="email"
                  required
                >
                <button type="submit" aria-label="Anmelden">
                  {{ 'icon-arrow.svg' | inline_asset_content }}
                </button>
              </div>
              {%- if form.posted_successfully? -%}
                <p class="site-footer__newsletter-success" role="status">Danke – du bist angemeldet.</p>
              {%- endif -%}
              {%- if form.errors -%}
                <p class="site-footer__newsletter-error" role="alert">{{ form.errors | default_errors }}</p>
              {%- endif -%}
            {%- endform -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Policies row (auto-linked to Shopify shop policies) {%- endcomment -%}
  {%- if section.settings.show_policies -%}
    <div class="site-footer__policies">
      <ul role="list">
        {%- if shop.privacy_policy -%}
          <li><a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title | escape }}</a></li>
        {%- endif -%}
        {%- if shop.terms_of_service -%}
          <li><a href="{{ shop.terms_of_service.url }}">{{ shop.terms_of_service.title | escape }}</a></li>
        {%- endif -%}
        {%- if shop.refund_policy -%}
          <li><a href="{{ shop.refund_policy.url }}">{{ shop.refund_policy.title | escape }}</a></li>
        {%- endif -%}
        {%- if shop.shipping_policy -%}
          <li><a href="{{ shop.shipping_policy.url }}">{{ shop.shipping_policy.title | escape }}</a></li>
        {%- endif -%}
        {%- if shop.subscription_policy -%}
          <li><a href="{{ shop.subscription_policy.url }}">{{ shop.subscription_policy.title | escape }}</a></li>
        {%- endif -%}
      </ul>
    </div>
  {%- endif -%}

  {%- comment -%} Bottom bar: copyright + payments + locale/country {%- endcomment -%}
  <div class="site-footer__bottom">
    <div class="site-footer__copy">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}
      {%- if section.settings.show_powered -%} · {{ powered_by_link }}{%- endif -%}
    </div>

    {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
      <div class="site-footer__country">
        {%- form 'localization', id: 'FooterCountryForm', class: 'site-footer__localization' -%}
          <label for="FooterCountry-{{ section.id }}">Land/Region</label>
          <select id="FooterCountry-{{ section.id }}" name="country_code" onchange="this.form.submit()">
            {%- for country in localization.available_countries -%}
              <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
              </option>
            {%- endfor -%}
          </select>
        {%- endform -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_payments -%}
      <ul class="site-footer__payments" role="list" aria-label="Zahlungsmethoden">
        {%- for type in shop.enabled_payment_types -%}
          <li>{{ type | payment_type_svg_tag }}</li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</footer>

{% style %}
  #shopify-section-{{ section.id }} {
    --footer-bg: {{ section.settings.bg_color }};
    --footer-fg: {{ section.settings.text_color }};
    --footer-heading: {{ section.settings.heading_color }};
    --footer-padding-top: {{ section.settings.padding_top }}px;
    --footer-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "section-site-footer",
  "settings": [
    {
      "type": "header",
      "content": "Marke"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer-Logo"
    },
    {
      "type": "richtext",
      "id": "about",
      "label": "Kurzbeschreibung",
      "default": "<p>Moderne Fashion-Brand für jeden Tag. Nachhaltig gedacht, zeitlos geschnitten.</p>"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_socials",
      "label": "Social Icons anzeigen",
      "default": true
    },
    { "type": "url", "id": "social_instagram", "label": "Instagram URL" },
    { "type": "url", "id": "social_tiktok", "label": "TikTok URL" },
    { "type": "url", "id": "social_facebook", "label": "Facebook URL" },
    { "type": "url", "id": "social_youtube", "label": "YouTube URL" },
    { "type": "url", "id": "social_pinterest", "label": "Pinterest URL" },
    {
      "type": "header",
      "content": "Rechtliches (Shopify-Policies)"
    },
    {
      "type": "paragraph",
      "content": "AGB, Datenschutz, Widerrufsbelehrung, Impressum & Versand werden automatisch aus deinen Shopify-Richtlinien gezogen (Einstellungen → Richtlinien)."
    },
    {
      "type": "checkbox",
      "id": "show_policies",
      "label": "Policies-Zeile anzeigen",
      "default": true
    },
    {
      "type": "header",
      "content": "Unten-Leiste"
    },
    {
      "type": "checkbox",
      "id": "show_payments",
      "label": "Zahlungs-Icons anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Länder-/Währungsauswahl anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_powered",
      "label": "„Powered by Shopify\" anzeigen",
      "default": false
    },
    {
      "type": "header",
      "content": "Farben"
    },
    { "type": "color", "id": "bg_color", "label": "Hintergrund", "default": "#0f0f0f" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#e6e6e6" },
    { "type": "color", "id": "heading_color", "label": "Überschriften", "default": "#ffffff" },
    {
      "type": "header",
      "content": "Abstände"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Oben", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Unten", "default": 40 }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menü-Spalte",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "heading", "label": "Überschrift", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menü" }
      ]
    },
    {
      "type": "text",
      "name": "Text-Spalte",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "heading", "label": "Überschrift", "default": "Hilfe" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Kontakt: hallo@dein-shop.de<br>Mo–Fr 9–17 Uhr</p>" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Überschrift", "default": "Newsletter" },
        { "type": "text", "id": "text", "label": "Text", "default": "10 % auf deine erste Bestellung – exklusive Drops vorab." },
        { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "E-Mail-Adresse" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu" },
        { "type": "menu" },
        { "type": "menu" },
        { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
