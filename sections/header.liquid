<header
  class="site-header {% if section.settings.sticky %}site-header--sticky{% endif %} site-header--{{ section.settings.layout }}"
  role="banner"
  data-section-id="{{ section.id }}"
>
  <a class="site-header__skip" href="#MainContent">Zum Inhalt springen</a>

  <div class="site-header__inner">
    {%- comment -%} LEFT: Burger + optional category label {%- endcomment -%}
    <div class="site-header__left">
      <button
        type="button"
        class="site-header__burger"
        aria-label="Kategorien öffnen"
        aria-expanded="false"
        aria-controls="mega-menu-drawer"
        data-drawer-toggle="mega-menu"
      >
        {{ 'icon-menu.svg' | inline_asset_content }}
        {%- if section.settings.burger_label != blank -%}
          <span class="site-header__burger-label">{{ section.settings.burger_label | escape }}</span>
        {%- endif -%}
      </button>
    </div>

    {%- comment -%} CENTER: Logo OR main menu depending on layout {%- endcomment -%}
    <div class="site-header__center">
      {%- if section.settings.layout == 'logo_left' -%}
        {%- render 'site-logo', settings: section.settings -%}
        {%- if section.settings.show_main_menu -%}
          {%- render 'site-main-menu', menu: section.settings.main_menu -%}
        {%- endif -%}
      {%- else -%}
        {%- if section.settings.show_main_menu -%}
          {%- render 'site-main-menu', menu: section.settings.main_menu -%}
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- comment -%} CENTER LOGO (logo_center layout) {%- endcomment -%}
    {%- if section.settings.layout == 'logo_center' -%}
      <div class="site-header__logo-center">
        {%- render 'site-logo', settings: section.settings -%}
      </div>
    {%- endif -%}

    {%- comment -%} RIGHT: Icons {%- endcomment -%}
    <div class="site-header__right">
      {%- if section.settings.show_search -%}
        <button type="button" class="site-header__icon" aria-label="Suche öffnen"
                aria-expanded="false" aria-controls="search-drawer" data-drawer-toggle="search">
          {{ 'icon-search.svg' | inline_asset_content }}
        </button>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled and section.settings.show_account -%}
        <a href="{{ routes.account_url }}" class="site-header__icon" aria-label="Konto">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="site-header__icon site-header__cart" aria-label="Warenkorb">
        {{ 'icon-cart.svg' | inline_asset_content }}
        <span class="site-header__cart-count" data-cart-count aria-live="polite">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  {%- comment -%} SEARCH DRAWER {%- endcomment -%}
  {%- if section.settings.show_search -%}
    <div id="search-drawer" class="site-drawer site-drawer--search" data-drawer="search" aria-hidden="true">
      <div class="site-drawer__backdrop" data-drawer-close></div>
      <div class="site-drawer__panel site-drawer__panel--top" role="dialog" aria-label="Suche" aria-modal="true">
        <form action="{{ routes.search_url }}" method="get" role="search" class="site-drawer__search-form">
          <input type="hidden" name="type" value="product">
          <input
            type="search"
            name="q"
            placeholder="Wonach suchst du?"
            class="site-drawer__search-input"
            autocomplete="off"
            enterkeyhint="search"
          >
          <button type="submit" class="site-drawer__search-submit" aria-label="Suchen">
            {{ 'icon-search.svg' | inline_asset_content }}
          </button>
          <button type="button" class="site-drawer__close" data-drawer-close aria-label="Suche schließen">
            {{ 'icon-close.svg' | inline_asset_content }}
          </button>
        </form>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} MEGA MENU DRAWER (Burger) {%- endcomment -%}
  <div id="mega-menu-drawer" class="site-drawer site-drawer--mega" data-drawer="mega-menu" aria-hidden="true">
    <div class="site-drawer__backdrop" data-drawer-close></div>
    <nav class="site-drawer__panel site-drawer__panel--left" role="dialog" aria-label="Kategorien" aria-modal="true">
      <div class="site-drawer__header">
        <span class="site-drawer__title">{{ section.settings.drawer_title | escape | default: 'Kategorien' }}</span>
        <button type="button" class="site-drawer__close" data-drawer-close aria-label="Schließen">
          {{ 'icon-close.svg' | inline_asset_content }}
        </button>
      </div>

      <div class="site-drawer__menu">
        {%- if section.settings.drawer_menu != blank -%}
          <ul class="site-drawer__list" role="list">
            {%- for link in section.settings.drawer_menu.links -%}
              <li class="site-drawer__item {% if link.links.size > 0 %}site-drawer__item--has-children{% endif %}">
                {%- if link.links.size > 0 -%}
                  <details class="site-drawer__details">
                    <summary class="site-drawer__summary">
                      <span>{{ link.title | escape }}</span>
                      {{ 'icon-chevron.svg' | inline_asset_content }}
                    </summary>
                    <ul class="site-drawer__sublist" role="list">
                      <li><a class="site-drawer__sublink site-drawer__sublink--all" href="{{ link.url }}">Alle {{ link.title | escape }}</a></li>
                      {%- for sub in link.links -%}
                        <li>
                          <a class="site-drawer__sublink" href="{{ sub.url }}">{{ sub.title | escape }}</a>
                          {%- if sub.links.size > 0 -%}
                            <ul class="site-drawer__sub2list" role="list">
                              {%- for sub2 in sub.links -%}
                                <li><a class="site-drawer__sub2link" href="{{ sub2.url }}">{{ sub2.title | escape }}</a></li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  </details>
                {%- else -%}
                  <a class="site-drawer__link" href="{{ link.url }}">{{ link.title | escape }}</a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- else -%}
          <p class="site-drawer__empty">Lege im Theme-Editor ein Menü für den Burger an (z.B. „fashion-kategorien") mit Einträgen wie „Damen", „Herren", „Jacken" und Unterkategorien.</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="site-drawer__extra">
            {%- for block in section.blocks -%}
              <div class="site-drawer__extra-item" {{ block.shopify_attributes }}>
                {%- case block.type -%}
                  {%- when 'promo_card' -%}
                    {%- if block.settings.image != blank -%}
                      <a href="{{ block.settings.link | default: '#' }}" class="site-drawer__promo">
                        {{ block.settings.image | image_url: width: 600 | image_tag:
                           loading: 'lazy',
                           sizes: '(min-width: 990px) 320px, 80vw',
                           widths: '320,480,640',
                           alt: block.settings.heading | default: 'Promo' | escape,
                           class: 'site-drawer__promo-image' }}
                        <div class="site-drawer__promo-content">
                          <strong>{{ block.settings.heading | escape }}</strong>
                          {%- if block.settings.text != blank -%}<p>{{ block.settings.text | escape }}</p>{%- endif -%}
                        </div>
                      </a>
                    {%- endif -%}
                  {%- when 'text_link' -%}
                    {%- if block.settings.link != blank -%}
                      <a href="{{ block.settings.link }}" class="site-drawer__text-link">{{ block.settings.text | escape }}</a>
                    {%- endif -%}
                {%- endcase -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </nav>
  </div>
</header>

{%- comment -%} Inline snippets for logo + menu (used above) {%- endcomment -%}

{% style %}
  #shopify-section-{{ section.id }} {
    --header-bg: {{ section.settings.bg_color }};
    --header-fg: {{ section.settings.text_color }};
    --header-height: {{ section.settings.height }}px;
    --header-accent: {{ section.settings.accent_color }};
  }
{% endstyle %}

{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'site-header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "section-site-header",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Logo-Position",
      "default": "logo_center",
      "options": [
        { "value": "logo_left", "label": "Logo links, Menü rechts vom Logo" },
        { "value": "logo_center", "label": "Logo zentriert, Menü links" }
      ]
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Header beim Scrollen fixieren",
      "default": true
    },
    {
      "type": "range",
      "id": "height",
      "min": 56,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Header-Höhe",
      "default": 80
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo-Bild"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo-Breite",
      "default": 140
    },
    {
      "type": "header",
      "content": "Haupt-Menü"
    },
    {
      "type": "checkbox",
      "id": "show_main_menu",
      "label": "Haupt-Menü anzeigen",
      "info": "Ein-/ausblenden ohne das Menü zu löschen.",
      "default": true
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Menü",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Burger / Kategorien-Drawer"
    },
    {
      "type": "text",
      "id": "burger_label",
      "label": "Burger-Beschriftung (optional)",
      "info": "Text neben dem Burger-Icon, z. B. „Shop\". Leer lassen für nur Icon."
    },
    {
      "type": "text",
      "id": "drawer_title",
      "label": "Drawer-Überschrift",
      "default": "Kategorien"
    },
    {
      "type": "link_list",
      "id": "drawer_menu",
      "label": "Zweites Menü (z. B. Damen / Herren / Jacken)",
      "info": "Verschachteltes Menü mit Unterpunkten wird als Mega-Drawer gerendert."
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Suche anzeigen",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Konto anzeigen",
      "default": true
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrund",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text / Icons",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akzent (Cart-Zähler, Hover)",
      "default": "#111111"
    }
  ],
  "blocks": [
    {
      "type": "promo_card",
      "name": "Promo-Kachel (Drawer)",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "heading", "label": "Titel", "default": "Neue Kollektion" },
        { "type": "text", "id": "text", "label": "Untertitel", "default": "Jetzt entdecken" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "text_link",
      "name": "Text-Link (Drawer)",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Sale" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ]
}
{% endschema %}
