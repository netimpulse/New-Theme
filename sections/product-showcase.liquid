{%- liquid
  assign product = section.settings.product
  assign has_product = false
  if product \!= blank
    assign has_product = true
  endif
  if has_product
    assign current_variant = product.selected_or_first_available_variant
  endif
  assign form_id = 'product-form-' | append: section.id
-%}

<section class="product-showcase" data-section-id="{{ section.id }}">
  <div class="product-showcase__grid">
    {%- comment -%} ====== MEDIA SIDE ====== {%- endcomment -%}
    <div class="product-showcase__media">
      {%- comment -%} Tab switcher (Video / 3D / Images) {%- endcomment -%}
      {%- liquid
        assign has_video = false
        assign has_3d = false
        if section.settings.video \!= blank or section.settings.video_url \!= blank
          assign has_video = true
        endif
        assign first_model = nil
        if has_product
          for media in product.media
            if media.media_type == 'model'
              assign first_model = media
              break
            endif
          endfor
        endif
        if first_model \!= nil
          assign has_3d = true
        endif
      -%}

      <div class="product-showcase__tabs" role="tablist">
        {%- if has_video -%}
          <button type="button" class="product-showcase__tab is-active" role="tab" data-media-tab="video" aria-selected="true">Video</button>
        {%- endif -%}
        {%- if has_3d -%}
          <button type="button" class="product-showcase__tab {% unless has_video %}is-active{% endunless %}" role="tab" data-media-tab="model" aria-selected="{% if has_video %}false{% else %}true{% endif %}">3D-Ansicht</button>
        {%- endif -%}
        {%- if has_product -%}
          <button type="button" class="product-showcase__tab {% unless has_video or has_3d %}is-active{% endunless %}" role="tab" data-media-tab="gallery" aria-selected="{% if has_video or has_3d %}false{% else %}true{% endif %}">Bilder</button>
        {%- endif -%}
      </div>

      {%- comment -%} ===== VIDEO PANEL ===== {%- endcomment -%}
      {%- if has_video -%}
        <div class="product-showcase__panel is-active" data-media-panel="video">
          <product-video
            class="product-video"
            data-autoplay-once="{{ section.settings.autoplay_once }}"
            data-replay-on-hover="true"
          >
            {%- if section.settings.video \!= blank -%}
              {%- liquid
                assign poster_src = ''
                if section.settings.last_frame \!= blank
                  assign poster_src = section.settings.last_frame | image_url: width: 1200
                elsif section.settings.video.preview_image \!= blank
                  assign poster_src = section.settings.video.preview_image | image_url: width: 1200
                endif
              -%}
              <video
                class="product-video__el"
                playsinline
                muted
                preload="metadata"
                {% if poster_src \!= '' %}poster="{{ poster_src }}"{% endif %}
              >
                {%- for source in section.settings.video.sources -%}
                  <source src="{{ source.url }}" type="video/{{ source.format }}">
                {%- endfor -%}
              </video>
            {%- elsif section.settings.video_url \!= blank -%}
              <div class="product-video__embed">
                {%- if section.settings.video_url.type == 'youtube' -%}
                  <iframe
                    src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&controls=0&playsinline=1&rel=0&modestbranding=1"
                    title="Produkt-Video"
                    frameborder="0"
                    allow="autoplay; encrypted-media; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                {%- else -%}
                  <iframe
                    src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&muted=1&controls=0"
                    title="Produkt-Video"
                    frameborder="0"
                    allow="autoplay; fullscreen; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if section.settings.last_frame \!= blank -%}
              <img
                class="product-video__poster"
                {{ section.settings.last_frame | image_url: width: 1600 | image_tag:
                   loading: 'lazy',
                   sizes: '(min-width: 990px) 50vw, 100vw',
                   widths: '600,900,1200,1600',
                   alt: 'Produkt-Standbild' | escape }}
              >
            {%- else -%}
              <canvas class="product-video__poster product-video__poster--canvas" aria-hidden="true"></canvas>
            {%- endif -%}

            <button type="button" class="product-video__replay" aria-label="Video erneut abspielen">
              {{ 'icon-play.svg' | inline_asset_content }}
            </button>
          </product-video>
        </div>
      {%- endif -%}

      {%- comment -%} ===== 3D MODEL PANEL ===== {%- endcomment -%}
      {%- if has_3d -%}
        <div class="product-showcase__panel {% unless has_video %}is-active{% endunless %}" data-media-panel="model">
          <product-model class="product-model">
            {{
              first_model
              | model_viewer_tag:
                reveal: 'interaction',
                toggleable: true,
                image_size: '1600x',
                loading: 'lazy'
            }}
          </product-model>
        </div>
      {%- endif -%}

      {%- comment -%} ===== GALLERY PANEL (product images) ===== {%- endcomment -%}
      {%- if has_product -%}
        <div class="product-showcase__panel {% unless has_video or has_3d %}is-active{% endunless %}" data-media-panel="gallery">
          <div class="product-showcase__gallery">
            {%- for media in product.media limit: 6 -%}
              {%- if media.media_type == 'image' -%}
                {{
                  media
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 990px) 45vw, 100vw',
                    widths: '450,600,900,1200',
                    alt: media.alt | default: product.title | escape,
                    class: 'product-showcase__gallery-image'
                }}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ====== INFO / FORM SIDE ====== {%- endcomment -%}
    <div class="product-showcase__info">
      {%- if section.settings.eyebrow \!= blank -%}
        <p class="product-showcase__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      <h2 class="product-showcase__title">
        {%- if has_product -%}
          <a href="{{ product.url }}">{{ product.title | escape }}</a>
        {%- else -%}
          {{ section.settings.fallback_title | default: 'Produkt auswählen' | escape }}
        {%- endif -%}
      </h2>

      {%- if has_product and product.vendor \!= blank and section.settings.show_vendor -%}
        <p class="product-showcase__vendor">{{ product.vendor | escape }}</p>
      {%- endif -%}

      {%- if section.settings.description \!= blank -%}
        <div class="product-showcase__desc">{{ section.settings.description }}</div>
      {%- elsif has_product -%}
        <div class="product-showcase__desc">{{ product.description | truncatewords: 80 }}</div>
      {%- endif -%}

      {%- if has_product -%}
        <div class="product-showcase__price" data-price-wrap>
          {%- render 'product-price', product: product, variant: current_variant -%}
        </div>

        <product-form
          class="product-form"
          data-section="{{ section.id }}"
          data-product-url="{{ product.url }}"
          data-product-handle="{{ product.handle }}"
        >
          <script type="application/json" data-product-json>
            {{ product.variants | json }}
          </script>

          {%- form 'product', product, id: form_id, class: 'product-form__form', novalidate: 'novalidate' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>

            {%- unless product.has_only_default_variant -%}
              <div class="product-form__options">
                {%- for option in product.options_with_values -%}
                  {%- liquid
                    assign option_handle = option.name | handle
                    assign is_color = false
                    if option_handle contains 'color' or option_handle contains 'farbe'
                      assign is_color = true
                    endif
                  -%}
                  <fieldset class="product-form__fieldset" data-option-index="{{ forloop.index0 }}">
                    <legend class="product-form__legend">
                      <span class="product-form__option-name">{{ option.name | escape }}</span>
                      <span class="product-form__option-value" data-option-value="{{ forloop.index0 }}">{{ option.selected_value | escape }}</span>
                    </legend>
                    <div class="product-form__swatches product-form__swatches--{% if is_color %}color{% else %}size{% endif %}">
                      {%- for value in option.values -%}
                        <label class="product-form__swatch {% if option.selected_value == value %}is-selected{% endif %}">
                          <input
                            type="radio"
                            name="options[{{ option.name | escape }}]"
                            value="{{ value | escape }}"
                            data-option-input="{{ forloop.parentloop.index0 }}"
                            {% if option.selected_value == value %}checked{% endif %}
                          >
                          {%- if is_color -%}
                            <span class="product-form__swatch-color" style="background: {{ value | handle }};" aria-hidden="true"></span>
                          {%- endif -%}
                          <span class="product-form__swatch-label">{{ value | escape }}</span>
                        </label>
                      {%- endfor -%}
                    </div>
                  </fieldset>
                {%- endfor -%}
              </div>
            {%- endunless -%}

            <div class="product-form__quantity">
              <label for="Quantity-{{ section.id }}">Menge</label>
              <div class="product-form__quantity-input">
                <button type="button" aria-label="Weniger" data-qty-minus>−</button>
                <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1" inputmode="numeric">
                <button type="button" aria-label="Mehr" data-qty-plus>+</button>
              </div>
            </div>

            <button
              type="submit"
              class="product-form__submit"
              data-add-to-cart
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <span data-atc-label>
                {% if current_variant.available %}In den Warenkorb{% else %}Ausverkauft{% endif %}
              </span>
            </button>

            {%- if section.settings.show_buy_now -%}
              <button type="button" class="product-form__buy-now" data-buy-now>Sofort kaufen</button>
            {%- endif -%}
          {%- endform -%}

          {%- if section.settings.show_meta -%}
            <ul class="product-showcase__meta" role="list">
              {%- if section.settings.meta_1 \!= blank -%}<li>{{ section.settings.meta_1 | escape }}</li>{%- endif -%}
              {%- if section.settings.meta_2 \!= blank -%}<li>{{ section.settings.meta_2 | escape }}</li>{%- endif -%}
              {%- if section.settings.meta_3 \!= blank -%}<li>{{ section.settings.meta_3 | escape }}</li>{%- endif -%}
            </ul>
          {%- endif -%}

          {%- comment -%} Extra info blocks (accordion) {%- endcomment -%}
          {%- if section.blocks.size > 0 -%}
            <div class="product-showcase__accordion">
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when 'accordion' -%}
                    <details class="product-showcase__accordion-item" {{ block.shopify_attributes }}>
                      <summary>
                        <span>{{ block.settings.heading | escape }}</span>
                        {{ 'icon-chevron.svg' | inline_asset_content }}
                      </summary>
                      <div class="product-showcase__accordion-body">{{ block.settings.content }}</div>
                    </details>
                {%- endcase -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </product-form>
      {%- else -%}
        <div class="product-showcase__empty">
          <p>Wähle im Theme-Editor ein Produkt aus, um Varianten (Größe, Farbe) und den Warenkorb-Button zu aktivieren.</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% style %}
  #shopify-section-{{ section.id }} {
    --ps-bg: {{ section.settings.bg_color }};
    --ps-fg: {{ section.settings.text_color }};
    --ps-accent: {{ section.settings.accent_color }};
    --ps-padding-top: {{ section.settings.padding_top }}px;
    --ps-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

{%- if has_3d -%}
  <script src="https://cdn.shopify.com/shopifycloud/model-viewer/v4.0/model-viewer.js" type="module"></script>
{%- endif -%}

{{ 'section-product-showcase.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-showcase.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Produkt-Showcase",
  "tag": "section",
  "class": "section-product-showcase",
  "settings": [
    {
      "type": "header",
      "content": "Produkt"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Produkt",
      "info": "Varianten (Größe, Farbe …) und Warenkorb-Button werden automatisch aus Shopify gezogen."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (kleiner Text oben)",
      "default": "Neu"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Titel-Fallback",
      "info": "Wird gezeigt wenn kein Produkt ausgewählt ist."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Beschreibung (überschreibt Produkt-Beschreibung)"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Marke anzeigen",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "„Sofort kaufen\"-Button",
      "default": false
    },
    {
      "type": "header",
      "content": "Video (Autoplay 1×, Hover-Replay)"
    },
    {
      "type": "paragraph",
      "content": "Video wird beim Laden einmal stumm abgespielt. Am Ende bleibt das letzte Frame als Standbild stehen (oder ein eigenes Bild – siehe unten). Beim Hovern über das Video wird es erneut abgespielt."
    },
    { "type": "video", "id": "video", "label": "Video (Shopify-Upload)" },
    { "type": "video_url", "id": "video_url", "label": "Alternativ: YouTube/Vimeo URL", "accept": ["youtube", "vimeo"] },
    {
      "type": "image_picker",
      "id": "last_frame",
      "label": "Standbild (letztes Frame)",
      "info": "Optional. Wird nach Ende des Videos angezeigt. Wenn leer, wird automatisch das letzte Frame gecapturt."
    },
    {
      "type": "checkbox",
      "id": "autoplay_once",
      "label": "Beim Laden einmal automatisch abspielen",
      "default": true
    },
    {
      "type": "header",
      "content": "3D-Modell"
    },
    {
      "type": "paragraph",
      "content": "3D-Modell für die interaktive Ansicht. Akzeptiert .glb / .gltf (Shopify-Upload)."
    },
    {
      "type": "header",
      "content": "Meta / USPs"
    },
    { "type": "checkbox", "id": "show_meta", "label": "Meta-Zeile anzeigen", "default": true },
    { "type": "text", "id": "meta_1", "label": "Meta 1", "default": "Kostenloser Versand ab 80 €" },
    { "type": "text", "id": "meta_2", "label": "Meta 2", "default": "30 Tage Rückgaberecht" },
    { "type": "text", "id": "meta_3", "label": "Meta 3", "default": "Nachhaltig produziert" },
    {
      "type": "header",
      "content": "Layout & Farben"
    },
    { "type": "color", "id": "bg_color", "label": "Hintergrund", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#111111" },
    { "type": "color", "id": "accent_color", "label": "Akzent (Buttons)", "default": "#111111" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Abstand oben", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Abstand unten", "default": 64 }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Akkordeon",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "heading", "label": "Überschrift", "default": "Details" },
        { "type": "richtext", "id": "content", "label": "Inhalt", "default": "<p>Material: 100 % Bio-Baumwolle · Made in Portugal</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Produkt-Showcase",
      "blocks": [
        { "type": "accordion", "settings": { "heading": "Details & Material" } },
        { "type": "accordion", "settings": { "heading": "Pflegehinweise" } },
        { "type": "accordion", "settings": { "heading": "Versand & Rückgabe" } }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
